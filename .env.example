# ============================================================
#  Smart Money Tracker — environment variables template
#  Copy this file to .env and fill in your values.
#  Lines starting with # are comments and are ignored.
# ============================================================

# ── Discord Bot ──────────────────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# OAuth2 invite link — TWO ways to configure (pick one):
#
# ┌─ Option A (easiest) ───────────────────────────────────────────────────┐
# │ Paste the full OAuth2 link from the Discord Developer Portal.         │
# │ Go to: Applications → Your App → OAuth2 → URL Generator              │
# │ Select scopes: bot + applications.commands                            │
# │ Select permissions, copy the generated URL and paste it below.        │
# │ When this is set, the /invite command uses it directly.               │
# └──────────────────────────────────────────────────────────────────┘
DISCORD_OAUTH_LINK=https://domain.com/redirect/discord

# ┌─ Option B (auto-build) ──────────────────────────────────────────────┐
# │ Fill these in and the bot builds the invite URL automatically.        │
# │ Found at: Applications → Your App → OAuth2 → General                 │
# │ Ignored when DISCORD_OAUTH_LINK is set.                              │
# └──────────────────────────────────────────────────────────────────┘
DISCORD_CLIENT_ID=123456789012345678
DISCORD_CLIENT_SECRET=your_client_secret_here

# Port the OAuth2 redirect callback server listens on.
# Discord will redirect users to https://yourdomain.com:<OAUTH_PORT>/callback
# after they authorise the bot.  Match this to the Redirect URI you set
# in the Discord Developer Portal → OAuth2 → Redirects.
OAUTH_PORT=8080

# Scopes included in the invite URL (space-separated).
# "bot applications.commands" is required for slash commands.
# Add "guilds" or "guilds.members.read" if you need server info.
DISCORD_OAUTH_SCOPES=bot applications.commands

# Integer permission bits for the invite URL.
# Default: VIEW_CHANNEL + SEND_MESSAGES + EMBED_LINKS +
#          READ_MESSAGE_HISTORY + USE_APPLICATION_COMMANDS
# Use https://discord.com/developers/docs/topics/permissions to build your own.
DISCORD_OAUTH_PERMISSIONS=2147568640

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot with @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ── API Server ───────────────────────────────────────────────────────────────
# IP and port Uvicorn binds on.
# Use 0.0.0.0 to accept connections from all network interfaces.
API_HOST=0.0.0.0
API_PORT=8000

# Public URL of this API server.
# ┌──────────────────────────────────────────────────────────────────┐
# │  IMPORTANT for external / Pterodactyl / VPS deployments          │
# │                                                                  │
# │  Set this so the Discord & Telegram bots reach the API over the  │
# │  network instead of localhost.  Examples:                         │
# │                                                                  │
# │  API_BASE_URL=http://1.2.3.4:8000          (IP + port)           │
# │  API_BASE_URL=http://your-vps.host:8000    (hostname + port)     │
# │  API_BASE_URL=https://tracker.example.com  (domain + reverse-proxy) │
# │                                                                  │
# │  Leave blank to fall back to http://localhost:{API_PORT}          │
# └──────────────────────────────────────────────────────────────────┘
API_BASE_URL=

# ── Blockchain RPC URLs ───────────────────────────────────────────────────────
# Provide a full RPC URL for each chain you want to monitor.
# Alchemy free tier is sufficient for most use cases:
#   https://dashboard.alchemy.com

# Ethereum mainnet
ALCHEMY_ETH=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Base mainnet
ALCHEMY_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Arbitrum One
ALCHEMY_ARB=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# Polygon mainnet
ALCHEMY_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optimism mainnet
ALCHEMY_OPT=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY

# BNB Smart Chain — public endpoint, no key needed
BSC_RPC=https://bsc-dataseed.binance.org/

# Optional: single Alchemy key — used as a fallback if per-chain URLs above are blank.
# ALCHEMY_API_KEY=YOUR_KEY

# ── Solana (Helius) ───────────────────────────────────────────────────────────
# Register at https://dev.helius.xyz — free tier supports 100 req/s
#
# Option A: provide just the API key — URL is derived automatically
# HELIUS_API_KEY=YOUR_HELIUS_KEY
#
# Option B: provide the full RPC URL (takes precedence over HELIUS_API_KEY)
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL + TimescaleDB (default, required):
DATABASE_URL=postgresql+asyncpg://smart_money:smart_money@localhost:5432/smart_money

# Docker deployment — use the service name as host:
# DATABASE_URL=postgresql+asyncpg://smart_money:smart_money@db:5432/smart_money

# Remote / custom credentials:
# DATABASE_URL=postgresql+asyncpg://user:password@your-host:5432/smart_money

# ── Whale Detection ───────────────────────────────────────────────────────────
# Minimum USD value of a transaction to be considered a "whale move".
WHALE_THRESHOLD_USD=10000

# ── Twitter / X Broadcasting ──────────────────────────────────────────────────
# Auto-post whale alerts, price alerts, and portfolio updates to Twitter/X.
# Set TWITTER_ENABLED=true to activate (requires API credentials below).
TWITTER_ENABLED=false

# Start in dry-run mode — tweets are logged and saved to DB but not posted.
# Set to false to go live after verifying previews via /twitter_test command.
TWITTER_DRY_RUN=true

# Twitter API v2 credentials (OAuth 1.0a User Context)
# Create an app at https://developer.x.com/en/portal/dashboard
# Required: Read and Write permissions
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Bearer token (optional — used for reading tweet metrics)
TWITTER_BEARER_TOKEN=

# Posting budget — max tweets per day and per hour
TWITTER_DAILY_BUDGET=50
TWITTER_HOURLY_CAP=17

# Feature flags — which alert types to tweet
TWITTER_ENABLE_WHALE_TWEETS=true
TWITTER_ENABLE_PRICE_TWEETS=true
TWITTER_ENABLE_PORTFOLIO_TWEETS=false

# Cooldown (hours) — min time between tweets about the same entity
# TWITTER_COOLDOWN_WALLET_HOURS=4.0
# TWITTER_COOLDOWN_TOKEN_HOURS=2.0
